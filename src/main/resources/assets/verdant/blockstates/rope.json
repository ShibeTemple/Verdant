{
  "multipart": [
    { "when": { "knotted": "true" }, "apply": { "model": "verdant:block/rope_knot" } },
    { "when": { "knotted": "false" }, "apply": { "model": "verdant:block/rope_base" } },
    { "when": { "north": "true" }, "apply": { "model": "verdant:block/rope_north" } },
    { "when": { "east": "true" }, "apply": { "model": "verdant:block/rope_east" } },
    { "when": { "south": "true" }, "apply": { "model": "verdant:block/rope_south" } },
    { "when": { "west": "true" }, "apply": { "model": "verdant:block/rope_west" } },
    { "when": { "up": "true" }, "apply": { "model": "verdant:block/rope_up" } },
    { "when": { "down": "true" }, "apply": { "model": "verdant:block/rope_down" } }
  ]
}
